{
  "name": "satisfactory-calculator",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "install": "npm ci",
  "terminals": [
    {
      "name": "dev",
      "command": "npm run dev",
      "description": "Next.js App Router dev server (static-export planner UI)"
    }
  ],
  "ports": [
    {
      "name": "web",
      "port": 3000
    }
  ]
}
